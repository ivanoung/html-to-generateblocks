{
  "name": "html-to-generateblocks",
  "version": "0.1.0",
  "description": "Convert HTML pages built with Tailwind CSS into GenerateBlocks WordPress block markup",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli/index.ts",
    "dev": "tsx watch src/cli/index.ts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^25.9.1",
    "tailwindcss": "^4.3.0",
    "tailwindcss3": "npm:tailwindcss@^3.4.19",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "keywords": ["generateblocks", "tailwindcss", "wordpress", "converter", "blocks"],
  "repository": {
    "type": "git",
    "url": "https://github.com/ivanoung/html-to-generateblocks"
  },
  "author": "Ivan Oung",
  "license": "GPL-3.0",
  "dependencies": {
    "cheerio": "^1.2.0",
    "css": "^3.0.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15"
  }
}
